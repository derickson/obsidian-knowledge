# Elasticsearch Serverless (data — search mirror)
ES_URL=https://your-project.es.us-east-1.aws.elastic.cloud:443
ES_API_KEY=your-api-key
# ES index names are per-vault, configured in vaults.json

# Elasticsearch Inference
ES_INFERENCE_ID=.jina-embeddings-v5-text-small

# Anthropic API (for post-processing pipeline and chat)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Obsidian Headless service
# Vault paths are per-vault, configured in vaults.json
VAULT_PATH=/app/vaults/AgentKnowledge
HEADLESS_URL=http://obsidian-headless:3104

# Server
API_PREFIX=/obsidian-knowledge

# MCP authentication (Bearer token for remote MCP clients)
MCP_API_KEY=your-mcp-api-key

# Elastic APM (Observability — separate from data Elasticsearch)
ELASTIC_APM_SERVER_URL=https://your-apm-endpoint.apm.cloud.elastic.co
ELASTIC_APM_SECRET_TOKEN=your-apm-secret-token
ELASTIC_APM_API_KEY=your-apm-api-key
ELASTIC_APM_ENVIRONMENT=development
